---
import { siteConfig } from "@/config/site";
import WhatsAppButton from "@/components/WhatsAppButton.astro";
---

<section class="hero">
  <img src="/images/maria-hero.png" alt="Mujer hispana en una cocina luminosa, estilo de vida familiar" />
  <div class="hero-shade" aria-hidden="true"></div>
  <div class="container hero-content">
    <p class="eyebrow">Sitio personal de recomendación</p>
    <h1>{siteConfig.siteName}</h1>
    <p>{siteConfig.tagline}</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="/productos">Ver productos recomendados</a>
      <WhatsAppButton label="Pedir ayuda personalizada" className="btn btn-secondary" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: clamp(560px, 82vh, 760px);
    align-items: end;
    overflow: hidden;
    background: #f6eadf;
  }

  img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgb(255 248 239 / 94%) 0%, rgb(255 248 239 / 72%) 38%, rgb(255 248 239 / 20%) 70%),
      linear-gradient(0deg, rgb(36 49 43 / 42%) 0%, transparent 40%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 0 0 72px;
  }

  h1 {
    max-width: 760px;
    margin: 12px 0 16px;
    font-size: clamp(3rem, 8vw, 6.4rem);
    line-height: 0.96;
  }

  p:not(.eyebrow) {
    max-width: 570px;
    margin: 0;
    color: #4f5b52;
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  @media (max-width: 720px) {
    .hero {
      min-height: 670px;
    }

    .hero-shade {
      background:
        linear-gradient(0deg, rgb(255 248 239 / 96%) 0%, rgb(255 248 239 / 72%) 62%, rgb(255 248 239 / 10%) 100%),
        linear-gradient(90deg, rgb(255 248 239 / 45%), transparent);
    }
  }
</style>
