---
import type { Product } from "@/data/products";
import WhatsAppButton from "@/components/WhatsAppButton.astro";

type Props = {
  product: Product;
};

const { product } = Astro.props;
const tone = product.category.toLowerCase().normalize("NFD").replace(/\p{Diacritic}/gu, "");
const message = `Hola María, me gustaría consultar sobre ${product.name}.`;
---

<article class="card product-card">
  <div class={`product-visual tone-${tone}`}>
    <span>{product.imageLabel}</span>
  </div>
  <div class="product-body">
    <p class="category">{product.category}</p>
    <h3>{product.name}</h3>
    <p>{product.shortDescription}</p>
    {(product.articleNumber || product.iboPrice) && (
      <dl class="product-meta">
        {product.articleNumber && (
          <>
            <dt>Artículo</dt>
            <dd>{product.articleNumber}</dd>
          </>
        )}
        {product.iboPrice && (
          <>
            <dt>Costo IBO</dt>
            <dd>{product.iboPrice}</dd>
          </>
        )}
      </dl>
    )}
    {product.availability && <p class="availability">{product.availability}</p>}
    <div class="actions">
      <a class="btn btn-primary" href={`/productos/${product.slug}`}>Ver detalle</a>
      <WhatsAppButton label="Consultar" message={message} className="btn btn-secondary" />
    </div>
  </div>
</article>

<style>
  .product-card {
    overflow: hidden;
  }

  .product-body {
    padding: 20px;
  }

  .category {
    margin: 0 0 8px;
    color: var(--rose);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0 0 10px;
    font-size: 1.35rem;
  }

  p:not(.category) {
    margin: 0;
    color: var(--soft);
    line-height: 1.65;
  }

  .product-meta {
    display: grid;
    gap: 8px;
    grid-template-columns: auto 1fr;
    margin: 16px 0 0;
    color: var(--soft);
    font-size: 0.92rem;
  }

  dt {
    font-weight: 850;
  }

  dd {
    margin: 0;
    color: var(--ink);
    font-weight: 850;
    text-align: right;
  }

  .availability {
    margin-top: 12px !important;
    color: #2d7a59 !important;
    font-weight: 850;
  }

  .actions {
    display: grid;
    gap: 10px;
    margin-top: 18px;
  }
</style>
