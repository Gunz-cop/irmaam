---
import { siteConfig } from "@/config/site";

const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/sobre-mi", label: "Sobre mí" },
  { href: "/productos", label: "Productos" },
  { href: "/paquetes", label: "Paquetes" },
  { href: "/blog", label: "Blog" },
  { href: "/contacto", label: "Contacto" },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <div class="header-top">
      <a class="brand" href="/" aria-label={siteConfig.siteName}>
        <span>MC</span>
        <strong>{siteConfig.siteName}</strong>
      </a>
      <details class="mobile-menu" data-mobile-menu>
        <summary class="menu-toggle" aria-label="Abrir menú">
          <span class="menu-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </summary>
        <button class="nav-backdrop" type="button" aria-hidden="true" tabindex="-1" data-menu-backdrop></button>
        <nav id="mobile-nav" aria-label="Navegación principal" data-site-nav>
          {navItems.map((item) => (
            <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </details>
    </div>
    <nav class="desktop-nav" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const menu = document.querySelector("[data-mobile-menu]");
  const header = document.querySelector(".site-header");
  const nav = document.querySelector("[data-site-nav]");
  const backdrop = document.querySelector("[data-menu-backdrop]");
  const links = nav?.querySelectorAll("a") ?? [];

  const setMenuState = (open) => {
    if (menu instanceof HTMLDetailsElement) {
      menu.open = open;
    }
    header?.toggleAttribute("data-open", open);
    document.body.classList.toggle("menu-open", open);
  };

  menu?.addEventListener("toggle", () => {
    const isOpen = menu instanceof HTMLDetailsElement ? menu.open : false;
    header?.toggleAttribute("data-open", isOpen);
    document.body.classList.toggle("menu-open", isOpen);
  });

  backdrop?.addEventListener("click", () => setMenuState(false));
  links.forEach((link) => link.addEventListener("click", () => setMenuState(false)));

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 821) setMenuState(false);
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenuState(false);
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgb(233 222 208 / 82%);
    background: rgb(255 253 249 / 92%);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    position: relative;
    padding: 12px 0;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .mobile-menu {
    position: relative;
    flex: 0 0 auto;
  }

  .mobile-menu summary {
    list-style: none;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 900;
  }

  .brand span {
    display: grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border-radius: 50%;
    background: #f3d5cd;
    color: #7a3442;
    font-size: 0.78rem;
  }

  .brand strong {
    font-size: 0.96rem;
    line-height: 1.15;
  }

  .menu-toggle {
    appearance: none;
    display: inline-flex;
    flex: 0 0 auto;
    width: 44px;
    min-width: 44px;
    width: 44px;
    height: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid #e9ded0;
    border-radius: 999px;
    background: rgb(255 255 255 / 82%);
    padding: 0;
    color: #24312b;
    line-height: 0;
    cursor: pointer;
  }

  .menu-icon {
    display: grid;
    gap: 4px;
  }

  .menu-icon span {
    display: block;
    width: 16px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition:
      transform 180ms ease,
      opacity 180ms ease;
  }

  .mobile-menu[open] .menu-icon span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-menu[open] .menu-icon span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu[open] .menu-icon span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .nav-backdrop {
    position: fixed;
    inset: 0;
    border: 0;
    background: rgb(36 49 43 / 24%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }

  .mobile-menu[open] .nav-backdrop {
    opacity: 1;
    pointer-events: auto;
  }

  .desktop-nav {
    display: none;
  }

  .mobile-menu nav {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    z-index: 2;
    display: grid;
    gap: 8px;
    width: min(320px, calc(100vw - 32px));
    border: 1px solid #eadfce;
    border-radius: 8px;
    background: rgb(255 251 246 / 98%);
    box-shadow: 0 26px 50px rgb(77 57 39 / 16%);
    padding: 14px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-8px);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .mobile-menu[open] nav {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  nav a {
    display: flex;
    min-height: 46px;
    align-items: center;
    border-radius: 8px;
    padding: 0 14px;
    color: #314039;
    font-size: 1rem;
    font-weight: 800;
  }

  nav a:hover {
    background: #f5ece2;
    color: #24312b;
  }

  nav a[aria-current="page"] {
    background: #f3d5cd;
    color: #7a3442;
  }

  @media (min-width: 821px) {
    .header-inner {
      padding: 0;
    }

    .header-top {
      min-height: 74px;
      gap: 28px;
      justify-content: space-between;
    }

    .mobile-menu {
      display: none;
    }

    .brand span {
      width: 42px;
      height: 42px;
      font-size: 0.86rem;
    }

    .brand strong {
      font-size: 1rem;
    }

    .desktop-nav {
      position: static;
      z-index: auto;
      display: flex;
      margin-left: auto;
      gap: 6px;
      border: 0;
      background: transparent;
      box-shadow: none;
      padding: 0;
      opacity: 1;
      pointer-events: auto;
      transform: none;
    }

    .desktop-nav a {
      min-height: auto;
      border-radius: 999px;
      padding: 9px 12px;
      font-size: 0.92rem;
      font-weight: 750;
    }
  }
</style>
