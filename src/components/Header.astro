---
import { siteConfig } from "@/config/site";

const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/sobre-mi", label: "Sobre mí" },
  { href: "/productos", label: "Productos" },
  { href: "/paquetes", label: "Paquetes" },
  { href: "/blog", label: "Blog" },
  { href: "/contacto", label: "Contacto" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={siteConfig.siteName}>
      <span>MC</span>
      <strong>{siteConfig.siteName}</strong>
    </a>
    <nav aria-label="Navegación principal">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgb(233 222 208 / 82%);
    background: rgb(255 253 249 / 92%);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: 10px;
    padding: 12px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 900;
  }

  .brand span {
    display: grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border-radius: 50%;
    background: #f3d5cd;
    color: #7a3442;
    font-size: 0.78rem;
  }

  .brand strong {
    font-size: 0.96rem;
    line-height: 1.15;
  }

  nav {
    display: flex;
    width: 100%;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 2px;
    scrollbar-width: none;
  }

  nav::-webkit-scrollbar {
    display: none;
  }

  nav a {
    flex: 0 0 auto;
    border-radius: 999px;
    padding: 8px 11px;
    color: #4d574f;
    font-size: 0.84rem;
    font-weight: 800;
    white-space: nowrap;
  }

  nav a:hover {
    background: #f5ece2;
    color: #24312b;
  }

  @media (min-width: 821px) {
    .header-inner {
      min-height: 74px;
      align-items: center;
      flex-direction: row;
      justify-content: space-between;
      gap: 28px;
      padding: 0;
    }

    nav {
      width: auto;
      flex-wrap: wrap;
      justify-content: flex-end;
      overflow: visible;
      padding-bottom: 0;
    }

    .brand span {
      width: 42px;
      height: 42px;
      font-size: 0.86rem;
    }

    .brand strong {
      font-size: 1rem;
    }

    nav a {
      padding: 9px 12px;
      font-size: 0.92rem;
      font-weight: 750;
    }
  }
</style>
