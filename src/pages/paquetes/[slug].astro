---
import CTASection from "@/components/CTASection.astro";
import DisclosureBanner from "@/components/DisclosureBanner.astro";
import WhatsAppButton from "@/components/WhatsAppButton.astro";
import { packages } from "@/data/packages";
import Layout from "@/layouts/Layout.astro";

export function getStaticPaths() {
  return packages.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const myShopHref = `/myshop-demo?item=${encodeURIComponent(item.name)}&type=paquete`;
---

<Layout title={item.name} description={item.description}>
  <section class="detail-hero">
    <div class="container detail-grid">
      <div>
        <p class="eyebrow">Paquete recomendado</p>
        <h1>{item.name}</h1>
        <p>{item.description}</p>
        {(item.articleNumber || item.iboPrice || item.retailPrice || item.pvBv || item.rating || item.availability) && (
          <dl class="commercial-info">
            {item.articleNumber && (
              <>
                <dt>N. de artículo</dt>
                <dd>{item.articleNumber}</dd>
              </>
            )}
            {item.iboPrice && (
              <>
                <dt>Costo al IBO</dt>
                <dd>{item.iboPrice}</dd>
              </>
            )}
            {item.retailPrice && (
              <>
                <dt>Precio minorista</dt>
                <dd>{item.retailPrice}</dd>
              </>
            )}
            {item.pvBv && (
              <>
                <dt>PV / BV</dt>
                <dd>{item.pvBv}</dd>
              </>
            )}
            {item.rating && (
              <>
                <dt>Reseñas</dt>
                <dd>{item.rating} / 5{item.reviews ? ` (${item.reviews})` : ""}</dd>
              </>
            )}
            {item.availability && (
              <>
                <dt>Disponibilidad</dt>
                <dd>{item.availability}</dd>
              </>
            )}
          </dl>
        )}
        <div class="actions">
          <a class="btn btn-primary" href={myShopHref}>Comprar en MyShop demo</a>
          <WhatsAppButton label="Pedir recomendación personalizada" message={`Hola María, quiero una recomendación sobre ${item.name}.`} />
        </div>
      </div>
      <aside class="card package-summary">
        <h2>Productos incluidos</h2>
        <ul>
          {item.includes.map((included) => <li>{included}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container info-grid">
      <article>
        <h2>Para quién es</h2>
        <p>{item.forWhom}</p>
      </article>
      <article>
        <h2>Beneficio práctico</h2>
        <p>{item.practicalBenefit}</p>
      </article>
      <article class="routine">
        <h2>Rutina sugerida</h2>
        <ol>
          {item.routine.map((step) => <li>{step}</li>)}
        </ol>
      </article>
      <DisclosureBanner />
    </div>
  </section>

  <CTASection
    title="Pide una versión ajustada a tu rutina."
    text="María podría ayudarte a elegir una selección inicial sin convertir el sitio personal en una tienda."
    primaryHref="/paquetes"
    primaryLabel="Volver a paquetes"
  />
</Layout>

<style>
  .detail-hero {
    background: #fbf3ea;
    padding: 72px 0;
  }

  .detail-grid,
  .info-grid {
    display: grid;
    gap: 28px;
    grid-template-columns: 1fr 0.8fr;
  }

  h1 {
    margin: 10px 0 16px;
    font-size: clamp(2.4rem, 10vw, 5.8rem);
    line-height: 0.96;
  }

  p,
  li {
    color: var(--soft);
    line-height: 1.75;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .commercial-info {
    display: grid;
    max-width: 520px;
    gap: 10px;
    grid-template-columns: minmax(140px, auto) 1fr;
    margin: 22px 0 0;
    border-top: 1px solid var(--line);
    padding-top: 18px;
  }

  .commercial-info dt {
    color: var(--soft);
    font-weight: 850;
  }

  .commercial-info dd {
    margin: 0;
    color: var(--ink);
    font-weight: 900;
    text-align: right;
  }

  .package-summary {
    padding: 24px;
  }

  h2 {
    margin: 0 0 12px;
    font-size: 1.55rem;
  }

  .info-grid article,
  .routine {
    border-bottom: 1px solid var(--line);
    padding-bottom: 20px;
  }

  .routine,
  .info-grid > :last-child {
    grid-column: 1 / -1;
  }

  @media (max-width: 820px) {
    .detail-grid,
    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
