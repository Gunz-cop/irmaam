---
import CTASection from "@/components/CTASection.astro";
import ProductCard from "@/components/ProductCard.astro";
import Layout from "@/layouts/Layout.astro";
import { products } from "@/data/products";
---

<Layout
  title="Productos recomendados"
  description="Grid de productos demo de nutrición, belleza y hogar para imaginar una experiencia de recomendación personalizada."
>
  <section class="page-heading">
    <div class="container">
      <p class="eyebrow">Productos demo</p>
      <h1>Recomendaciones organizadas por categoría.</h1>
      <p>
        Estos productos son simulados. No incluyen precios ni datos comerciales finales; sirven para mostrar
        cómo María podría presentar recomendaciones claras y consultables.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container product-grid">
      {products.map((product) => <ProductCard product={product} />)}
    </div>
  </section>

  <CTASection
    title="¿No sabes por dónde empezar?"
    text="Pide una recomendación personalizada y María podría orientarte según tus intereses."
    primaryHref="/paquetes"
    primaryLabel="Ver paquetes"
  />
</Layout>

<style>
  .page-heading {
    background: #fbf3ea;
    padding: 72px 0 52px;
  }

  h1 {
    max-width: 820px;
    margin: 10px 0 16px;
    font-size: clamp(3rem, 7vw, 5.6rem);
    line-height: 0.96;
  }

  .page-heading p:not(.eyebrow) {
    max-width: 720px;
    color: var(--soft);
    line-height: 1.75;
  }

  .product-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 920px) {
    .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
