---
import CTASection from "@/components/CTASection.astro";
import DisclosureBanner from "@/components/DisclosureBanner.astro";
import WhatsAppButton from "@/components/WhatsAppButton.astro";
import { products } from "@/data/products";
import Layout from "@/layouts/Layout.astro";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const tone = product.category.toLowerCase().normalize("NFD").replace(/\p{Diacritic}/gu, "");
const myShopHref = `/myshop-demo?item=${encodeURIComponent(product.name)}&type=producto`;
---

<Layout title={product.name} description={product.shortDescription}>
  <section class="detail-hero">
    <div class="container detail-grid">
      <div class={`product-visual tone-${tone}`}>
        <span>{product.imageLabel}</span>
      </div>
      <div class="content">
        <p class="eyebrow">{product.category}</p>
        <h1>{product.name}</h1>
        <p>{product.description}</p>
        {(product.articleNumber || product.iboPrice || product.retailPrice || product.pvBv || product.rating || product.availability) && (
          <dl class="commercial-info">
            {product.articleNumber && (
              <>
                <dt>N. de artículo</dt>
                <dd>{product.articleNumber}</dd>
              </>
            )}
            {product.iboPrice && (
              <>
                <dt>Costo al IBO</dt>
                <dd>{product.iboPrice}</dd>
              </>
            )}
            {product.retailPrice && (
              <>
                <dt>Precio minorista</dt>
                <dd>{product.retailPrice}</dd>
              </>
            )}
            {product.pvBv && (
              <>
                <dt>PV / BV</dt>
                <dd>{product.pvBv}</dd>
              </>
            )}
            {product.rating && (
              <>
                <dt>Reseñas</dt>
                <dd>{product.rating} / 5{product.reviews ? ` (${product.reviews})` : ""}</dd>
              </>
            )}
            {product.availability && (
              <>
                <dt>Disponibilidad</dt>
                <dd>{product.availability}</dd>
              </>
            )}
          </dl>
        )}
        <div class="actions">
          <a class="btn btn-primary" href={myShopHref}>Ir al MyShop demo</a>
          <WhatsAppButton message={`Hola María, quiero preguntar por ${product.name}.`} />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container detail-content">
      <article class="card info-card">
        <h2>Para quién puede servir</h2>
        <p>{product.forWhom}</p>
      </article>
      <article class="card info-card">
        <h2>Cómo se usa</h2>
        <p>{product.usage}</p>
      </article>
      <article class="card info-card">
        <h2>Por qué lo recomienda María</h2>
        <p>{product.mariaReason}</p>
      </article>
      <DisclosureBanner />
    </div>
  </section>

  <section class="sample-note">
    <div class="container">
      Información de referencia. Confirmar precio, disponibilidad e instrucciones oficiales antes de publicar o comprar.
    </div>
  </section>

  <CTASection
    title="¿Quieres comparar este producto con otra opción?"
    text="La idea es que puedas preguntar antes de decidir y revisar la información oficial cuando estés lista."
    primaryHref="/productos"
    primaryLabel="Volver a productos"
  />
</Layout>

<style>
  .detail-hero {
    background: #fbf3ea;
    padding: 72px 0;
  }

  .detail-grid {
    display: grid;
    align-items: center;
    gap: 36px;
    grid-template-columns: 0.9fr 1fr;
  }

  .product-visual {
    min-height: 430px;
    border-radius: 8px;
  }

  h1 {
    margin: 10px 0 16px;
    font-size: clamp(2.4rem, 10vw, 5.8rem);
    line-height: 0.96;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .commercial-info {
    display: grid;
    max-width: 520px;
    gap: 10px;
    grid-template-columns: minmax(140px, auto) 1fr;
    margin: 22px 0 0;
    border-top: 1px solid var(--line);
    padding-top: 18px;
  }

  .commercial-info dt {
    color: var(--soft);
    font-weight: 850;
  }

  .commercial-info dd {
    margin: 0;
    color: var(--ink);
    font-weight: 900;
    text-align: right;
  }

  .detail-content {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .info-card {
    padding: 24px;
  }

  .detail-content > :last-child {
    grid-column: 1 / -1;
  }

  h2 {
    margin: 0 0 10px;
    font-size: 1.45rem;
  }

  p {
    color: var(--soft);
    line-height: 1.75;
  }

  .sample-note {
    background: #fff2eb;
    padding: 18px 0;
    color: #7a3442;
    font-weight: 850;
  }

  @media (max-width: 820px) {
    .detail-grid,
    .detail-content {
      grid-template-columns: 1fr;
    }
  }
</style>
